# =================================
# TONIC — Environment Configuration
# =================================

# Development
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=tonic

# Server
PORT=3001
NODE_ENV=development

# AI API — Anthropic (for Score → iReal Pro feature)
# Get your API key from: https://console.anthropic.com/
AI_API_KEY=your_anthropic_api_key_here
AI_API_PROVIDER=anthropic

# ─── Firebase ──────────────────────────────────────────────────────────────────
# 1. Vai su https://console.firebase.google.com → Crea progetto "tonic-app"
# 2. Authentication → Sign-in method → Google → Abilita → Salva
# 3. Firestore Database → Crea database → Modalità produzione → Scegli regione
# 4. Impostazioni progetto (⚙) → Le tue app → Aggiungi app web → Copia config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Feature Flags (optional)
VITE_ENABLE_AI_VOICINGS=false
VITE_ENABLE_SCALE_RECOGNITION=false